# ==============================================================
# CacaoScan - Variables de entorno para PRODUCCION (Droplet)
# ==============================================================
# Copia este archivo como .env en la raiz del proyecto, en el droplet.
# Cambia TODOS los valores marcados con CHANGEME.
# ==============================================================

# --- Dominio y TLS ---
DOMAIN=cacaoscan.tudominio.com
LETSENCRYPT_EMAIL=tucorreo@tudominio.com

# --- Django ---
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGEME_genera_uno_largo_y_aleatorio

# --- Postgres ---
POSTGRES_DB=cacaoscan_db
POSTGRES_USER=cacaoscan
POSTGRES_PASSWORD=CHANGEME_password_fuerte

# --- Redis ---
REDIS_PASSWORD=CHANGEME_password_fuerte_distinto

# --- Seed inicial (solo en el primer deploy) ---
# Pon "true" la primera vez para cargar catalogos + datos Colombia.
# Despues vuelvelo "false" para acelerar reinicios.
SEED_INITIAL_DATA=true

# --- Email SMTP (opcional, si usas reset de password / verificacion) ---
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=
