{
  "name": "cacaoscan-frontend",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --coverage",
    "test:unit:dev": "vitest --coverage",
    "test:unit:watch": "vitest --coverage --watch",
    "test:fast:failed": "vitest --rerun-failed",
    "test:fast:changed": "vitest --changed",
    "test:fast:smart": "vitest --changed --rerun-failed",
    "test:all": "vitest run --coverage",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "axios": "^1.12.2",
    "chart.js": "^4.5.0",
    "ionicons": "^8.0.13",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.3",
    "sweetalert2": "^11.26.3",
    "tailwindcss": "^4.1.11",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "~10.3.0",
    "globals": "^16.3.0",
    "jsdom": "^29.1.0",
    "prettier": "3.6.2",
    "start-server-and-test": "^2.0.12",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}

