{
  "name": "cacaoscan-frontend",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --coverage",
    "test:unit:dev": "vitest --coverage",
    "test:unit:watch": "vitest --coverage --watch",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:admin": "cypress run --spec 'cypress/e2e/admin/**/*.cy.js'",
    "test:auth": "cypress run --spec 'cypress/e2e/auth/**/*.cy.js'",
    "test:fincas": "cypress run --spec 'cypress/e2e/fincas/**/*.cy.js'",
    "test:images": "cypress run --spec 'cypress/e2e/images/**/*.cy.js'",
    "test:reports": "cypress run --spec 'cypress/e2e/reports/**/*.cy.js'",
    "test:errors": "cypress run --spec 'cypress/e2e/errors/**/*.cy.js'",
    "test:navigation": "cypress run --spec 'cypress/e2e/navigation/**/*.cy.js'",
    "test:ui": "cypress run --spec 'cypress/e2e/ui/**/*.cy.js'",
    "test:agricultor": "cypress run --spec 'cypress/e2e/agricultor/**/*.cy.js'",
    "test:analysis": "cypress run --spec 'cypress/e2e/analysis/**/*.cy.js'",
    "test:audit": "cypress run --spec 'cypress/e2e/audit/**/*.cy.js'",
    "test:integration": "cypress run --spec 'cypress/e2e/integration/**/*.cy.js'",
    "test:performance": "cypress run --spec 'cypress/e2e/performance/**/*.cy.js'",
    "test:public": "cypress run --spec 'cypress/e2e/public/**/*.cy.js'",
    "test:security": "cypress run --spec 'cypress/e2e/security/**/*.cy.js'",
    "test:settings": "cypress run --spec 'cypress/e2e/settings/**/*.cy.js'",
    "test:accessibility": "cypress run --spec 'cypress/e2e/accessibility/**/*.cy.js'",
    "test:all:coverage": "vitest run --coverage && cypress run",
    "test:all": "vitest run --coverage && cypress run",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "axios": "^1.12.2",
    "chart.js": "^4.5.0",
    "ionicons": "^8.0.13",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.3",
    "sweetalert2": "^11.26.3",
    "tailwindcss": "^4.1.11",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "cypress": "^14.5.3",
    "eslint": "^9.31.0",
    "eslint-plugin-cypress": "^5.1.0",
    "eslint-plugin-vue": "~10.3.0",
    "globals": "^16.3.0",
    "jsdom": "^25.0.1",
    "prettier": "3.6.2",
    "start-server-and-test": "^2.0.12",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}

