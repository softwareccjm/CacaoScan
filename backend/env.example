# ============================================
# CACAOSCAN - Archivo de Configuración .env
# ============================================
# Copia este archivo a .env y configura los valores según tu entorno
# IMPORTANTE: Nunca subas el archivo .env al repositorio (está en .gitignore)
#
# Para generar una SECRET_KEY:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS POSTGRESQL
# ============================================
# IMPORTANTE: Cambia estas credenciales por valores seguros en producción
DB_NAME=cacaoscan_db
DB_USER=cacaoscan_user
DB_PASSWORD=CHANGE_THIS_PASSWORD_IN_PRODUCTION
DB_HOST=localhost
DB_PORT=5432

# Alternativas (también soportadas):
# POSTGRES_DB=cacaoscan_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Base de datos para tests
POSTGRES_DB_TEST=cacaoscan_db_test

# ============================================
# CONFIGURACIÓN DE DJANGO
# ============================================
# IMPORTANTE: Esta SECRET_KEY debe ser única y segura.
# Genera una nueva con:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION

# Modo de desarrollo (True) o producción (False)
DEBUG=True

# Hosts permitidos (separados por comas)
# En desarrollo: localhost,127.0.0.1
# En producción: tudominio.com,www.tudominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Entorno de la aplicación (development/production)
APP_ENV=development

# ============================================
# CONFIGURACIÓN DE REDIS
# ============================================
# Habilitar/deshabilitar Redis (True/False)
# Si es False, se usará caché en memoria (solo desarrollo)
# Para producción, siempre usar True
USE_REDIS=False

# Configuración de conexión Redis
# Host de Redis (localhost para instalación local, o IP del servidor Redis)
# Para Render: usar servicio Redis externo (Upstash, Redis Cloud, etc.)
REDIS_HOST=localhost

# Puerto de Redis (por defecto 6379)
# Para SSL: generalmente 6380
REDIS_PORT=6379

# Base de datos Redis (0-15, por defecto 0)
REDIS_DB=0

# Contraseña de Redis (dejar vacío si no tiene contraseña)
# Para servicios externos (Upstash, Redis Cloud): siempre requerida
REDIS_PASSWORD=

# ============================================
# CONFIGURACIÓN DE CELERY
# ============================================
# Habilitar/deshabilitar Celery con Redis (True/False)
# Si es False, se usará broker en memoria (solo desarrollo, NO producción)
# Para análisis asíncronos, siempre usar True
USE_CELERY_REDIS=True

# URL del broker de Celery (Redis)
# Formato: redis://[password@]host[:port][/database]
# Ejemplo sin contraseña: redis://localhost:6379/0
# Ejemplo con contraseña: redis://:password@localhost:6379/0
# Para Render con Upstash: redis://:password@host.upstash.io:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# URL del backend de resultados de Celery (Redis)
# Formato: redis://[password@]host[:port][/database]
# Ejemplo sin contraseña: redis://localhost:6379/0
# Ejemplo con contraseña: redis://:password@localhost:6379/0
# Para Render con Upstash: redis://:password@host.upstash.io:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# CONFIGURACIÓN DE EMAIL
# ============================================
# Backend de email
# Desarrollo: django.core.mail.backends.console.EmailBackend
# Producción: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Configuración SMTP (Gmail, SendGrid, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=CHANGE_THIS_EMAIL_PASSWORD
EMAIL_TIMEOUT=30

# Email del remitente por defecto
DEFAULT_FROM_EMAIL=CacaoScan <noreply@cacaoscan.com>
SERVER_EMAIL=CacaoScan <noreply@cacaoscan.com>
EMAIL_SUBJECT_PREFIX=[CacaoScan] 

# Configuración de SendGrid (alternativa a SMTP)
# Si usas SendGrid, configura esto y cambia EMAIL_BACKEND a:
# django.core.mail.backends.smtp.EmailBackend
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@cacaoscan.com

# Habilitar notificaciones por email
EMAIL_NOTIFICATIONS_ENABLED=True

# Cola de emails (para producción con alto volumen)
EMAIL_QUEUE_ENABLED=False
EMAIL_BATCH_SIZE=50
EMAIL_RETRY_ATTEMPTS=3

# Email del administrador
ADMIN_EMAIL=admin@cacaoscan.com

# ============================================
# CONFIGURACIÓN DE CORS (Cross-Origin Resource Sharing)
# ============================================
# Orígenes permitidos (separados por comas)
# En desarrollo: http://localhost:5173,http://127.0.0.1:5173
# En producción: https://tudominio.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================
# CONFIGURACIÓN DE FRONTEND
# ============================================
# URL del frontend (usada para enlaces en emails, etc.)
# En desarrollo: http://localhost:5173
# En producción: https://tudominio.com
FRONTEND_URL=http://localhost:5173

# URL base de la API (usada por el frontend)
# En desarrollo: http://localhost:8000/api/v1
# En producción: https://api.tudominio.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ============================================
# CONFIGURACIÓN DE WEBSOCKETS Y NOTIFICACIONES EN TIEMPO REAL
# ============================================
# URL del WebSocket
# En desarrollo: ws://localhost:8000/ws/
# En producción: wss://api.tudominio.com/ws/
WEBSOCKET_URL=ws://localhost:8000/ws/

# Intervalo de heartbeat para WebSockets (segundos)
WEBSOCKET_HEARTBEAT_INTERVAL=30

# Máximo de conexiones WebSocket simultáneas
WEBSOCKET_MAX_CONNECTIONS=1000

# Habilitar notificaciones en tiempo real
REALTIME_NOTIFICATIONS_ENABLED=True
NOTIFICATION_BROADCAST_ENABLED=True
NOTIFICATION_PERSISTENCE_ENABLED=True

# ============================================
# CONFIGURACIÓN DE ARCHIVOS ESTÁTICOS Y MEDIA
# ============================================
# Directorio para archivos estáticos (por defecto: staticfiles)
# Dejar vacío para usar el valor por defecto
DJANGO_STATIC_ROOT=

# Directorio para archivos media (por defecto: media)
# Dejar vacío para usar el valor por defecto
DJANGO_MEDIA_ROOT=

# Usar manifest de archivos estáticos (True/False)
USE_STATICFILES_MANIFEST=True

# ============================================
# CONFIGURACIÓN DE AWS S3 (Opcional)
# ============================================
# Habilitar almacenamiento en S3 (True/False)
# Si es False, se usará almacenamiento local
# IMPORTANTE: Cuando USE_S3=True, todas las imágenes de análisis se guardarán automáticamente en S3
USE_S3=False

# Credenciales de AWS (solo si USE_S3=True)
# 
# CÓMO OBTENER LAS CREDENCIALES DE AWS:
# 
# PASO 1: Crear un bucket S3
#   1. Inicia sesión en AWS Console: https://console.aws.amazon.com/
#   2. Ve a S3: https://console.aws.amazon.com/s3/
#   3. Clic en "Create bucket"
#   4. Nombre del bucket: cacaoscan-dataset (o el que prefieras)
#   5. Región: us-east-1 (o la que prefieras)
#   6. Deja las opciones por defecto y crea el bucket
#
# PASO 2: Crear un usuario IAM para acceso programático
#   1. Ve a IAM: https://console.aws.amazon.com/iam/
#   2. En el menú lateral, clic en "Users" (Usuarios)
#   3. Clic en "Create user" (Crear usuario)
#   4. Nombre de usuario: cacaoscan-s3-user (o el que prefieras)
#   5. Selecciona "Provide user access to the AWS Management Console" (opcional)
#   6. O mejor: "Access key - Programmatic access" (Acceso mediante clave de acceso)
#   7. Clic en "Next"
#
# PASO 3: Asignar permisos S3
#   1. Selecciona "Attach policies directly"
#   2. Busca y selecciona: "AmazonS3FullAccess" (para desarrollo)
#      O crea una política personalizada con solo estos permisos:
#      - s3:PutObject
#      - s3:GetObject
#      - s3:DeleteObject
#      - s3:ListBucket
#   3. Clic en "Next" y luego "Create user"
#
# PASO 4: Generar Access Keys
#   1. Una vez creado el usuario, clic en su nombre
#   2. Ve a la pestaña "Security credentials" (Credenciales de seguridad)
#   3. En "Access keys", clic en "Create access key"
#   4. Selecciona "Application running outside AWS" (Aplicación fuera de AWS)
#   5. Clic en "Next" y luego "Create access key"
#   6. IMPORTANTE: Copia el "Access key ID" y el "Secret access key"
#      ⚠️ La Secret Access Key solo se muestra UNA VEZ. Guárdala de forma segura.
#
# PASO 5: Configurar en el archivo .env
#   Copia los valores aquí:
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_STORAGE_BUCKET_NAME=cacaoscan-dataset
AWS_S3_REGION_NAME=us-east-1
#
# NOTA: Los valores de ejemplo arriba NO son válidos. Reemplázalos con tus credenciales reales.

# NOTA: Cuando USE_S3=True:
# - Las imágenes subidas durante análisis se guardan automáticamente en S3
# - El sistema descarga temporalmente las imágenes desde S3 para procesamiento (segmentación)
# - Las imágenes procesadas también se guardan en S3
# - No es necesario configurar MEDIA_ROOT cuando se usa S3

# ============================================
# CONFIGURACIÓN DE ENTRENAMIENTO AUTOMÁTICO
# ============================================
# Habilitar entrenamiento automático de modelos (0/1)
# 0 = Deshabilitado
# 1 = Habilitado
AUTO_TRAIN_ENABLED=0

# ============================================
# CONFIGURACIÓN DE SEGURIDAD (Producción)
# ============================================
# Redireccionar HTTP a HTTPS (solo en producción)
# En desarrollo: False
# En producción: True
SECURE_SSL_REDIRECT=False

# CSRF Trusted Origins (orígenes confiables para CSRF)
# En desarrollo: se configuran automáticamente para localhost
# En producción: lista los dominios desde donde se accederá al admin
# Ejemplo: http://localhost:8000,https://tudominio.com
# Si está vacío, en desarrollo se usan valores por defecto
CSRF_TRUSTED_ORIGINS=

# ============================================
# CONFIGURACIÓN DE DOCKER Y RENDER
# ============================================
# Rol del servicio (para docker-entrypoint.sh)
# Valores posibles: web, celery-worker, celery-beat
# En desarrollo local: no es necesario
# En Render: se configura automáticamente en render.yaml
SERVICE_ROLE=web

# Habilitar creación de datos iniciales (catálogos, etc.)
# En desarrollo: True
# En producción: True (solo en el primer deploy)
SEED_INITIAL_DATA=True

# ============================================
# CONFIGURACIÓN DE SUPERUSUARIO (Render/Producción)
# ============================================
# Habilitar creación automática de superusuario
# IMPORTANTE: Solo habilitar en producción si tienes las variables configuradas
# En desarrollo: False (crear manualmente con createsuperuser)
# En Render: True (con las variables configuradas en Dashboard)
DJANGO_CREATE_SUPERUSER=False

# Credenciales del superusuario (solo si DJANGO_CREATE_SUPERUSER=true)
# IMPORTANTE: NO poner estas variables en render.yaml por seguridad
# Configurarlas en Render Dashboard > Environment Variables
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@cacaoscan.com
DJANGO_SUPERUSER_PASSWORD=CHANGE_THIS_PASSWORD_MIN_8_CHARS

# ============================================
# CONFIGURACIÓN ADICIONAL
# ============================================
# Modo de prueba (para tests)
# No configurar manualmente, se establece automáticamente durante tests
DJANGO_TEST_MODE=0

# ============================================
# NOTAS IMPORTANTES PARA RENDER
# ============================================
# 
# 1. REDIS:
#    - Render no tiene servicio Redis nativo
#    - Usar servicio externo (Upstash, Redis Cloud, etc.)
#    - Configurar REDIS_HOST, REDIS_PORT, REDIS_PASSWORD en Render Dashboard
#    - Configurar CELERY_BROKER_URL y CELERY_RESULT_BACKEND en Render Dashboard
#
# 2. SUPERUSUARIO:
#    - NO poner DJANGO_SUPERUSER_PASSWORD en render.yaml
#    - Configurarla en Render Dashboard > Environment Variables
#    - Habilitar DJANGO_CREATE_SUPERUSER=true en render.yaml
#
# 3. SECRET_KEY:
#    - Debe ser la misma para todos los servicios (backend, worker, beat)
#    - Configurarla manualmente en Render Dashboard para cada servicio
#    - O usar generateValue: true en render.yaml (solo para backend)
#
# 4. BASE DE DATOS:
#    - Render configura automáticamente DB_* desde la base de datos
#    - No es necesario configurarlas manualmente
#
# 5. CELERY:
#    - Requiere Redis configurado
#    - Worker y Beat son servicios separados en Render
#    - Ambos deben tener las mismas variables de entorno que el backend
#
# ============================================
# EJEMPLO DE CONFIGURACIÓN PARA RENDER
# ============================================
# 
# Variables a configurar en Render Dashboard para cada servicio:
#
# Backend, Celery Worker, Celery Beat:
# - USE_REDIS=true
# - USE_CELERY_REDIS=true
# - REDIS_HOST=your-redis-host.upstash.io
# - REDIS_PORT=6379
# - REDIS_PASSWORD=your-redis-password
# - REDIS_DB=0
# - CELERY_BROKER_URL=redis://:password@host:6379/0
# - CELERY_RESULT_BACKEND=redis://:password@host:6379/0
# - SECRET_KEY=your-secret-key (misma para todos)
#
# Solo Backend:
# - DJANGO_CREATE_SUPERUSER=true
# - DJANGO_SUPERUSER_USERNAME=admin
# - DJANGO_SUPERUSER_EMAIL=admin@cacaoscan.com
# - DJANGO_SUPERUSER_PASSWORD=secure-password-here
#
# ============================================
