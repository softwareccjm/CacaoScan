# ==============================
# Configuración de Base de Datos PostgreSQL
# ==============================
# REQUIRED: Database configuration
# Option 1: Individual variables (nombres antiguos - compatibilidad)
DB_NAME=cacaoscan_db
DB_USER=cacaoscan
DB_PASSWORD=cambia_est0!
DB_HOST=db
DB_PORT=5432

# Option 2: Variables POSTGRES_* (nombres nuevos - recomendadas)
# Estas variables tienen prioridad sobre las DB_* si están definidas
POSTGRES_DB=cacaoscan_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Base de datos para tests (REQUERIDA para pytest)
POSTGRES_DB_TEST=cacaoscan_db_test

# Option 3: DATABASE_URL (alternative, takes precedence if set)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ==============================
# Configuración de Django
# ==============================
# REQUIRED: Generate SECRET_KEY with:
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
# Or use: python manage.py shell -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend,backend-service,app.cacaoscan.com
APP_ENV=production

# ==============================
# Configuración de API
# ==============================
VITE_API_BASE_URL=http://backend:8000/api/v1

# ==============================
# Configuración de Email (Gmail)
# ==============================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password
DEFAULT_FROM_EMAIL=CacaoScan <tu-email@gmail.com>

# ==============================
# Entorno y Frontend
# ==============================
APP_ENV=production
FRONTEND_URL=https://app.cacaoscan.com
REDIS_PASSWORD=protege_redis
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# ==============================
# Configuración de CORS
# ==============================
CORS_ALLOWED_ORIGINS=https://app.cacaoscan.com

# ==============================
# Configuración de AWS S3
# ==============================
USE_S3=False
AWS_ACCESS_KEY_ID=AKIAXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
AWS_STORAGE_BUCKET_NAME=cacaoscan-dataset
AWS_S3_REGION_NAME=us-east-1