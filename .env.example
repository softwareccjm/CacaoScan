# ==============================
# CacaoScan - Configuración Docker Compose
# ==============================
# Copia este archivo como .env en la raíz del proyecto y configura las variables necesarias

# ==============================
# Base de Datos PostgreSQL
# ==============================
POSTGRES_DB=cacaoscan_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# ==============================
# Configuración de Base de Datos para Backend
# ==============================
DB_NAME=cacaoscan_db
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=db
DB_PORT=5432

# ==============================
# Configuración de Django
# ==============================
SECRET_KEY=tu-secret-key-muy-seguro-aqui-cambiar-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend

# ==============================
# Configuración de Redis y Celery
# ==============================
USE_REDIS=True
REDIS_PASSWORD=tu_password_seguro_123
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==============================
# Configuración de Frontend
# ==============================
VITE_API_BASE_URL=http://localhost:8000/api/v1
FRONTEND_URL=http://localhost:5173

# ==============================
# Configuración de CORS
# ==============================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==============================
# Configuración de Email (Opcional)
# ==============================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password
DEFAULT_FROM_EMAIL=CacaoScan <tu-email@gmail.com>

# ==============================
# Configuración de AWS S3 (Opcional)
# ==============================
USE_S3=False
AWS_ACCESS_KEY_ID=AKIAXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
AWS_STORAGE_BUCKET_NAME=cacaoscan-dataset
AWS_S3_REGION_NAME=us-east-1
