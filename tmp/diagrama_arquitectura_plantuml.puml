@startuml CacaoScan Architecture

!define RECTANGLE class

package "Frontend (Vue.js)" {
    component "Stores (Pinia)" as Stores {
        note right of Stores
            Clases:
            - auth
            - admin
            - analysis
            - audit
            - config
            - fincas
            - notifications
            - prediction
            - reports
        end note
    }
    
    component "Services (API Clients)" as FrontendServices {
        note right of FrontendServices
            Clases:
            - api
            - apiClient
            - httpClient
            - authApi
            - adminApi
            - auditApi
            - catalogosApi
            - configApi
            - datasetApi
            - fincasApi
            - lotesApi
            - personasApi
            - predictionApi
            - reportsApi
            - reportsService
            - dashboardStatsService
        end note
    }
    
    component "Composables" as Composables {
        note right of Composables
            Clases:
            - useAuth
            - useAdminView
            - useAnalysis
            - useAudit
            - useChart
            - useDashboardStats
            - useFincas
            - useLotes
            - useNotifications
            - usePagination
            - usePrediction
            - useReports
            - useWebSocket
        end note
    }
    
    component "Views" as FrontendViews {
        note right of FrontendViews
            Componentes Vue:
            - LoginView
            - DashboardView
            - FincasView
            - AnalysisView
            - ReportsView
            - AdminView
        end note
    }
}

package "Backend (Django)" {
    package "Controllers / Views" {
        component "Auth Views" as AuthViews {
            note right of AuthViews
                Clases:
                - LoginView
                - RegisterView
                - LogoutView
                - UserProfileView
                - RefreshTokenView
                - ChangePasswordView
                - EmailVerificationView
            end note
        }
        
        component "Fincas Views" as FincasViews {
            note right of FincasViews
                Clases:
                - FincaListCreateView
                - FincaDetailView
                - FincaUpdateView
                - FincaDeleteView
                - FincaStatsView
                - LoteListCreateView
                - LoteDetailView
            end note
        }
        
        component "Images Views" as ImagesViews {
            note right of ImagesViews
                Clases:
                - ScanMeasureView
                - ImagesListView
                - ImageDetailView
                - ImagesStatsView
                - BatchAnalysisView
            end note
        }
        
        component "ML Views" as MLViews {
            note right of MLViews
                Clases:
                - TrainingJobListView
                - TrainingJobCreateView
                - ModelMetricsListView
                - CalibrationView
                - IncrementalTrainingView
                - ModelsStatusView
            end note
        }
        
        component "Reports Views" as ReportsViews {
            note right of ReportsViews
                Clases:
                - ReporteListCreateView
                - ReporteDetailView
                - ReporteDownloadView
                - ReporteAgricultoresView
            end note
        }
        
        component "Admin Views" as AdminViews {
            note right of AdminViews
                Clases:
                - ActivityLogListView
                - LoginHistoryListView
                - SystemSettingsView
                - TaskStatusView
            end note
        }
    }
    
    package "Services" {
        component "Base Services" as BaseServices {
            note right of BaseServices
                Clases:
                - BaseService
                - ServiceResult
                - ServiceError
                - ValidationServiceError
                - PermissionServiceError
                - NotFoundServiceError
            end note
        }
        
        component "Auth Services" as AuthServices {
            note right of AuthServices
                Clases:
                - LoginService
                - RegistrationService
                - PasswordService
                - VerificationService
                - ProfileService
            end note
        }
        
        component "Business Services" as BusinessServices {
            note right of BusinessServices
                Clases:
                - AnalysisService
                - StatsService
                - FincaService
                - LoteService
                - ImageManagementService
                - ImageProcessingService
                - ImageStorageService
                - ReportService
                - ReportGenerationService
            end note
        }
        
        component "ML Services" as MLServices {
            note right of MLServices
                Clases:
                - MLService
                - PredictionService
            end note
        }
    }
    
    package "Models / Entities" {
        component "Domain Models" as DomainModels {
            note right of DomainModels
                Clases:
                - Finca
                - Lote
                - CacaoImage
                - CacaoPrediction
                - TrainingJob
                - ModelMetrics
                - Persona
                - UserProfile
                - Notification
                - ActivityLog
                - LoginHistory
                - ReporteGenerado
                - SystemSettings
            end note
        }
        
        component "Catalog Models" as CatalogModels {
            note right of CatalogModels
                Clases:
                - Departamento
                - Municipio
                - Tema
                - Parametro
            end note
        }
    }
    
    package "ML / AI Engine" {
        component "Data Loaders" as DataLoaders {
            note right of DataLoaders
                Clases:
                - CacaoDatasetLoader
                - CacaoDataset
                - HybridDataset
                - PixelFeatureExtractor
            end note
        }
        
        component "Regression Models" as RegressionModels {
            note right of RegressionModels
                Clases:
                - MultiHeadRegression
                - HybridCacaoRegression
                - create_model
            end note
        }
        
        component "Segmentation" as Segmentation {
            note right of Segmentation
                Clases:
                - CacaoCropper
                - YOLOSegmentationInference
            end note
        }
        
        component "Training Pipeline" as TrainingPipeline {
            note right of TrainingPipeline
                Clases:
                - train_all
                - hybrid_training
                - hybrid_v2_training
                - train_single_model
                - train_multi_head_model
            end note
        }
        
        component "Prediction" as Prediction {
            note right of Prediction
                Clases:
                - get_predictor
                - load_artifacts
                - calibrated_predict
            end note
        }
    }
    
    package "Tasks / Workers" {
        component "Celery Tasks" as CeleryTasks {
            note right of CeleryTasks
                Clases:
                - train_model_task
                - auto_train_model_task
                - image_tasks
                - ml_tasks
                - stats_tasks
                - token_cleanup
            end note
        }
    }
    
    package "Utils / Helpers" {
        component "API Utils" as APIUtils {
            note right of APIUtils
                Clases:
                - decorators
                - ml_helpers
                - pagination
                - permissions
            end note
        }
        
        component "ML Utils" as MLUtils {
            note right of MLUtils
                Clases:
                - early_stopping
                - losses
                - metrics
                - scalers
                - paths
                - io
            end note
        }
    }
}

package "Infrastructure" {
    component "Database" as Database {
        note right of Database
            PostgreSQL
        end note
    }
    
    component "Cache" as Cache {
        note right of Cache
            Redis
        end note
    }
    
    component "Message Queue" as MessageQueue {
        note right of MessageQueue
            Celery + Redis
        end note
    }
    
    component "WebSockets" as WebSockets {
        note right of WebSockets
            Channels + Redis
        end note
    }
}

' Relaciones Frontend
FrontendViews --> Composables
Composables --> Stores
Composables --> FrontendServices
Stores --> FrontendServices
FrontendServices --> "Backend API" as BackendAPI

' Relaciones Controllers -> Services
AuthViews --> AuthServices
FincasViews --> BusinessServices
ImagesViews --> BusinessServices
MLViews --> MLServices
ReportsViews --> BusinessServices
AdminViews --> BusinessServices

' Relaciones Services -> Models
AuthServices --> DomainModels
BusinessServices --> DomainModels
MLServices --> DomainModels
BusinessServices --> CatalogModels

' Relaciones Services -> ML Engine
MLServices --> Prediction
MLServices --> RegressionModels
BusinessServices --> Segmentation
BusinessServices --> DataLoaders

' Relaciones Tasks
CeleryTasks --> TrainingPipeline
CeleryTasks --> BusinessServices
CeleryTasks --> MLServices

' Relaciones Infrastructure
DomainModels --> Database
BusinessServices --> Cache
CeleryTasks --> MessageQueue
WebSockets --> Cache

' Relaciones ML Pipeline
TrainingPipeline --> RegressionModels
TrainingPipeline --> DataLoaders
Prediction --> RegressionModels
Segmentation --> DataLoaders

' Relaciones Utils
BusinessServices --> APIUtils
MLServices --> MLUtils
TrainingPipeline --> MLUtils

@enduml

